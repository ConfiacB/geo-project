{
  "singleQuote": true,
  "semi": true,
  "useTabs": false,
  "tabWidth": 2,
  "trailingComma": "all",
  "printWidth": 80,
  "arrowParens": "always",
  "quoteProps": "preserve",
  "overrides": [
    {
      "files": ["*.mts", "*.cts", "*.ts", "*.tsx"],
      "options": {
        "parser": "typescript"
      }
    }
  ]
}
