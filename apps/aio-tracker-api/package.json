{
  "name": "@myapp/aio-tracker-api",
  "version": "1.0.1",
  "description": "An AI SEO Express backend server in TypeScript.",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc",
    "coverage": "jest --runInBand --coverage",
    "dev": "nodemon --exec ts-node src/server.ts",
    "prepare": "husky install",
    "prestart": "npm run build",
    "start": "node dist/server.js",
    "test": "jest --runInBand"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.28.0",
    "@types/node": "^24.9.1",
    "axios": "^1.12.2",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^10.0.0",
    "express": "^4.21.2",
    "mongoose": "^6.13.8",
    "multer": "^2.0.2",
    "serpapi": "^2.2.1",
    "uuid": "^13.0.0",
    "winston": "^3.3.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.24",
    "@types/jest": "^26.0.23",
    "@types/mongoose": "^5.11.96",
    "@types/multer": "^2.0.0",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^4.27.0",
    "@typescript-eslint/parser": "^4.27.0",
    "eslint": "^7.28.0",
    "husky": "^6.0.0",
    "jest": "^27.0.4",
    "lint-staged": "^11.0.0",
    "nodemon": "^3.1.10",
    "playwright": "^1.56.1",
    "prettier": "^2.3.1",
    "supertest": "^6.1.3",
    "ts-jest": "^27.0.3",
    "ts-node": "^10.0.0",
    "typescript": "^4.3.2"
  },
  "lint-staged": {
    "*.{js,ts,json}": [
      "eslint .",
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  }
}
